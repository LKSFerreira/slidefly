# =============================================================================
# VARIÁVEIS DE AMBIENTE (DEVELOPMENT)
# =============================================================================

# --- Banco de Dados (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=slidefly_db

# --- Conexão (Internal Docker Network) ---
# IMPORTANTE: O host deve ser 'database' (nome do serviço no compose.yaml)
DATABASE_URL=postgresql://postgres:postgres@database:5432/slidefly_db

# --- Configurações de Ambiente ---
NODE_ENV=development
APP_ENV=local

# --- Portas Expostas ---
PORT=5173
